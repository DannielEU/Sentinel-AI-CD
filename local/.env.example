# ══════════════════════════════════════════════════════════════════════════════
# Sentinel AI-CD — Configuración LOCAL
# Copia este archivo: cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ─── PROVEEDOR DE IA ──────────────────────────────────────────────────────────
# Opciones: ollama | openai | anthropic | disabled
# - ollama     : LLM local (requiere descargar el modelo, sin costo)
# - openai     : Requiere OPENAI_API_KEY
# - anthropic  : Requiere ANTHROPIC_API_KEY
# - disabled   : Solo motor de reglas (sin análisis IA)
AI_PROVIDER=ollama

# ─── OLLAMA ───────────────────────────────────────────────────────────────────
# Modelo a usar. mistral es el recomendado para análisis de seguridad.
# Opciones: mistral | neural-chat | llama2 | llama3 | qwen2.5
OLLAMA_MODEL=mistral

# Puerto expuesto de Ollama en tu máquina local
OLLAMA_PORT=11434

# ─── OPENAI (solo si AI_PROVIDER=openai) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── ANTHROPIC (solo si AI_PROVIDER=anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── SENTINEL GATE ────────────────────────────────────────────────────────────
# Puerto expuesto de la API en tu máquina local
GATE_PORT=8000

# Token de autenticación Bearer (dejar vacío para deshabilitar en local)
# Generar con: python3 ../scripts/generate_token.py
GATE_AUTH_TOKEN=

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# SQLite (default, no requiere servicios extra):
DATABASE_URL=sqlite+aiosqlite:///./data/sentinel.db

# PostgreSQL (requiere: docker compose --profile postgres up -d):
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel

# ─── POSTGRESQL (solo si usas --profile postgres) ────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
POSTGRES_PORT=5432

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW=60
AUTH_FAILURE_LIMIT=10
AUTH_FAILURE_WINDOW=300

# ─── UMBRALES DE SEGURIDAD (motor de reglas) ──────────────────────────────────
# Tamaño máximo de imagen en MB antes de WARNING
MAX_IMAGE_SIZE_MB=1200

# Vulnerabilidades HIGH: > umbral = REJECTED
MAX_HIGH_VULNS=10

# Vulnerabilidades MEDIUM: > umbral = WARNING
MAX_MEDIUM_VULNS=30
