# ── Sentinel AI-CD Configuration ──────────────────────────────────────────
# Copy this file to .env and configure for your environment
# Para Azure: configurar variables según el servicio

# ═════════════════════════════════════════════════════════════════════════════
# OLLAMA CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Ollama server URL (local por defecto)
# Local: http://localhost:11434 o http://ollama:11434 (Docker)
# Azure: URL del servicio de IA (si se usa externo)
OLLAMA_URL=http://ollama:11434

# Modelo de IA a usar
# Opciones: neural-chat (recomendado), mistral, llama2, openchat
# neural-chat: Optimizado para análisis técnico y seguridad Docker
OLLAMA_MODEL=neural-chat

# Puerto de Ollama (default 11434)
OLLAMA_PORT=11434

# ═════════════════════════════════════════════════════════════════════════════
# FASTAPI GATE CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Puerto del servicio FastAPI (default 8000)
GATE_PORT=8000

# Habilitar/Deshabilitar análisis con IA
# true = usar solo rule engine (rápido, determinístico)
# false = usar IA cuando rules no disparan (más contexto)
AI_DISABLED=false

# Token de autenticación (Bearer Token)
# Generar con: python3 scripts/generate_token.py
# Dejar vacío para deshabilitar autenticación
GATE_AUTH_TOKEN=

# Rate Limiting (DDoS Protection)
# Máximo número de requests por ventana de tiempo
RATE_LIMIT_REQUESTS=100

# Ventana de tiempo para rate limit (en segundos)
RATE_LIMIT_WINDOW=60

# Máximo número de fallos de autenticación permitidos
AUTH_FAILURE_LIMIT=5

# Ventana de tiempo para fallos de autenticación (en segundos)
AUTH_FAILURE_WINDOW=300

# Orígenes CORS permitidos (separados por comas)
# Ejemplos: http://localhost,http://localhost:8000,https://yourci.com
CORS_ORIGINS=http://localhost,http://localhost:8000,http://localhost:8080

# Deshabilitar documentación API en producción
DISABLE_DOCS=false

# ═════════════════════════════════════════════════════════════════════════════
# SECURITY THRESHOLDS (Rule Engine)
# ═════════════════════════════════════════════════════════════════════════════

# Tamaño máximo de imagen permitido (en MB)
# Recomendado: 1200MB
# Si excede: WARNING
MAX_IMAGE_SIZE_MB=1200

# Máximo número de vulnerabilidades HIGH permitidas
# Recomendado: 10
# Si > 10: REJECTED
# Si 1-10: WARNING
MAX_HIGH_VULNS=10

# Máximo número de vulnerabilidades MEDIUM permitidas
# Recomendado: 30
# Si > 30: WARNING
MAX_MEDIUM_VULNS=30

# ═════════════════════════════════════════════════════════════════════════════
# DOCKER RESOURCE LIMITS (docker-compose)
# ═════════════════════════════════════════════════════════════════════════════

# Limite de CPU para Ollama (ej: "2" = 2 CPUs)
# Recomendado: 2 para IA model, 1 para gate
OLLAMA_CPU_LIMIT=2

# Limite de memoria para Ollama (ej: "4G")
# Recomendado: 4G minimum para neural-chat
OLLAMA_MEMORY_LIMIT=4G

# ═════════════════════════════════════════════════════════════════════════════
# CI/CD INTEGRATION (ci.yml)
# ═════════════════════════════════════════════════════════════════════════════

# Imagen de Docker a construir
# Default: auto-detectado desde github.repository
# IMAGE_NAME=myorg/myapp:v1.0.0

# ═════════════════════════════════════════════════════════════════════════════
# AZURE DEPLOYMENT OPTIONS
# ═════════════════════════════════════════════════════════════════════════════

# Para Azure Container Instances:
# - Usar docker-compose con OLLAMA_URL apuntando a servicio externo
# - O desplegar Ollama en ACR y referenciar

# Para Azure App Service:
# - Usar variables de entorno en Configuration > Application settings
# - OLLAMA_URL debe ser accesible (no localhost)

# Ejemplo para Azure:
# OLLAMA_URL=https://my-ai-service.cognitiveservices.azure.com/
