# Sentinel-AI-CD — Variables de entorno PRODUCCIÓN (Azure)
# =========================================================
# Copia este archivo a .env.prod, rellena los valores y NUNCA lo subas al repo.
# Referencia: docker-compose.prod.yml
#
# Arquitectura:
#   Gate (FastAPI) → Azure  |  Ollama → EC2  |  DB → Azure PostgreSQL

# ═════════════════════════════════════════════════════════════════════════════
# IMAGEN (solo si usas Azure Container Registry)
# ═════════════════════════════════════════════════════════════════════════════
# ACR_LOGIN_SERVER=miregistry.azurecr.io
# IMAGE_TAG=latest

# ═════════════════════════════════════════════════════════════════════════════
# PROVEEDOR DE IA — Ollama en EC2
# ═════════════════════════════════════════════════════════════════════════════
# Opciones: ollama | openai | anthropic | disabled
AI_PROVIDER=ollama

# URL pública de la EC2 donde corre Ollama
# Puerto 11434 debe estar abierto en el Security Group de la EC2
# (solo desde la IP del gate en Azure, no desde internet en general)
OLLAMA_URL=http://<IP-PUBLICA-EC2>:11434
OLLAMA_MODEL=mistral

# --- Anthropic (alternativa si Ollama no está disponible) ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- OpenAI (alternativa si Ollama no está disponible) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_MODEL=gpt-4o-mini

# ═════════════════════════════════════════════════════════════════════════════
# BASE DE DATOS — Azure Database for PostgreSQL Flexible Server
# ═════════════════════════════════════════════════════════════════════════════
#
# Donde encontrar cada valor en el portal de Azure:
#   - servidor    → Portal > tu servidor PostgreSQL > "Server name"
#   - usuario     → Portal > tu servidor PostgreSQL > "Administrator login"
#   - password    → el que configuraste al crear el servidor
#   - dbname      → nombre de la BD que crees (recomendado: sentinel)
#
# Formato:
#   postgresql+asyncpg://<usuario>:<password>@<servidor>.postgres.database.azure.com:5432/<dbname>?ssl=require
DATABASE_URL=postgresql+asyncpg://sentineladmin:TuPasswordAqui@mi-servidor.postgres.database.azure.com:5432/sentinel?ssl=require

# ═════════════════════════════════════════════════════════════════════════════
# AUTENTICACIÓN Y SEGURIDAD
# ═════════════════════════════════════════════════════════════════════════════
# Genera un token seguro con: python3 scripts/generate_token.py
# Este token deben enviarlo los pipelines CI/CD en: Authorization: Bearer <TOKEN>
GATE_AUTH_TOKEN=

# Token separado para el dashboard web (si lo dejas vacío, usa GATE_AUTH_TOKEN)
DASHBOARD_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═════════════════════════════════════════════════════════════════════════════
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
AUTH_FAILURE_LIMIT=5
AUTH_FAILURE_WINDOW=300

# ═════════════════════════════════════════════════════════════════════════════
# CORS — Orígenes permitidos
# ═════════════════════════════════════════════════════════════════════════════
# Los pipelines de GitHub Actions no son navegadores, no les afecta CORS.
# Solo necesario si tienes un frontend SPA que llame a la API desde un dominio distinto.
CORS_ORIGINS=

# ═════════════════════════════════════════════════════════════════════════════
# API Y SERVIDOR
# ═════════════════════════════════════════════════════════════════════════════
GATE_PORT=8000
DISABLE_DOCS=true

# ═════════════════════════════════════════════════════════════════════════════
# UMBRALES DEL MOTOR DE REGLAS
# ═════════════════════════════════════════════════════════════════════════════
MAX_IMAGE_SIZE_MB=1200
MAX_HIGH_VULNS=10
MAX_MEDIUM_VULNS=30

# ═════════════════════════════════════════════════════════════════════════════
# RECURSOS DEL CONTENEDOR (solo gate; Ollama corre en EC2)
# ═════════════════════════════════════════════════════════════════════════════
GATE_CPU_LIMIT=1.0
GATE_MEMORY_LIMIT=256M
